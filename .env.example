# =====================
# Required
# =====================
DJANGO_SECRET_KEY=your-very-secret-key-here
GITHUB_TOKEN=your-github-personal-access-token
DJANGO_SETTINGS_MODULE=config.settings_prod
APP_BASE_URL=https://your-project.vercel.app

# =====================
# Database (PostgreSQL / Neon / Supabase / Railway)
# =====================
POSTGRES_DB=reporadar
POSTGRES_USER=reporadar
POSTGRES_PASSWORD=strongpasswordhere
DATABASE_URL=postgresql://reporadar:strongpasswordhere@db:5432/reporadar

# =====================
# Redis
# =====================
REDIS_URL=redis://redis:6379/0

# =====================
# Email notifications
# =====================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=RepoRadar <noreply@yourdomain.com>

# =====================
# Django
# =====================
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app,https://your-domain.com
